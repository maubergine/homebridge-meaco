{
  "pluginAlias": "MeacoPlatform",
  "pluginType": "platform",
  "singular": true,
  "strictValidation": true,
  "fixArrays": true,
  "headerDisplay": "Control your Meaco air conditioner from Apple Home via Tuya Cloud. You need a Tuya IoT account — see the README for setup instructions.",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Platform Name",
        "type": "string",
        "default": "Meaco"
      },
      "cloud_credentials": {
        "title": "Cloud Credentials",
        "type": "object",
        "properties": {
          "tuya_region": {
            "title": "Tuya Region",
            "type": "string",
            "default": "EU",
            "enum": ["US", "EU", "WEU", "CN", "IN"],
            "enumNames": ["Americas (US)", "Europe (EU)", "Western Europe", "China (CN)", "India (IN)"]
          },
          "tuya_access_key": {
            "title": "Access Key",
            "type": "string",
            "required": true
          },
          "tuya_secret_key": {
            "title": "Secret Key",
            "type": "string",
            "required": true
          }
        }
      },
      "devices": {
        "title": "Devices",
        "type": "array",
        "items": {
          "title": "Device",
          "type": "object",
          "properties": {
            "tuya_device_id": {
              "title": "Tuya Device ID",
              "type": "string",
              "required": true
            },
            "display_name": {
              "title": "Display Name",
              "type": "string",
              "default": "Air Conditioner"
            },
            "display_type": {
              "title": "Display Type",
              "type": "string",
              "default": "heater_cooler",
              "enum": ["heater_cooler", "thermostat", "fan_only"],
              "enumNames": ["Heater/Cooler (recommended)", "Thermostat", "Fan Only"]
            },
            "temperature_unit": {
              "title": "Temperature Unit",
              "type": "string",
              "default": "celsius",
              "enum": ["celsius", "fahrenheit"]
            },
            "expose_dry_mode_switch": {
              "title": "Expose Dry Mode Switch",
              "type": "boolean",
              "default": true
            },
            "expose_fan_only_mode_switch": {
              "title": "Expose Fan-Only Mode Switch",
              "type": "boolean",
              "default": true
            },
            "expose_swing_control": {
              "title": "Expose Swing Control",
              "type": "boolean",
              "default": true,
              "condition": {
                "functionBody": "return model.display_type !== 'thermostat';"
              }
            },
            "expose_sleep_mode_switch": {
              "title": "Expose Sleep Mode Switch",
              "type": "boolean",
              "default": false
            },
            "manufacturer": {
              "title": "Manufacturer",
              "type": "string",
              "default": "Meaco"
            },
            "model": {
              "title": "Model",
              "type": "string",
              "default": "MeacoCool MC"
            },
            "polling_interval_seconds": {
              "title": "Polling Interval (seconds)",
              "type": "integer",
              "default": 30,
              "minimum": 5,
              "maximum": 300
            },
            "unresponsive_after_failures": {
              "title": "Mark Unresponsive After N Failures",
              "type": "integer",
              "default": 3,
              "minimum": 1,
              "maximum": 10
            },
            "capability_overrides": {
              "title": "Capability Overrides",
              "type": "object",
              "properties": {
                "has_heat": { "type": "boolean" },
                "has_dry": { "type": "boolean" },
                "has_swing": { "type": "boolean" },
                "has_sleep": { "type": "boolean" },
                "has_fan_only": { "type": "boolean" },
                "has_auto": { "type": "boolean" },
                "temp_min": { "type": "number" },
                "temp_max": { "type": "number" }
              }
            }
          }
        }
      },
      "advanced_settings": {
        "title": "Advanced Settings",
        "type": "object",
        "expandable": true,
        "expanded": false,
        "properties": {
          "request_timeout_ms": {
            "title": "Request Timeout (ms)",
            "type": "integer",
            "default": 8000
          },
          "max_command_retries": {
            "title": "Max Command Verify Retries",
            "type": "integer",
            "default": 5
          },
          "command_verify_interval_ms": {
            "title": "Command Verify Interval (ms)",
            "type": "integer",
            "default": 1000
          },
          "debug_logging": {
            "title": "Enable Debug Logging",
            "type": "boolean",
            "default": false
          }
        }
      }
    }
  },
  "layout": [
    { "type": "section", "title": "Cloud Credentials", "expandable": false, "items": ["cloud_credentials.tuya_region", "cloud_credentials.tuya_access_key", "cloud_credentials.tuya_secret_key"] },
    { "type": "section", "title": "Devices", "expandable": false, "items": [{ "key": "devices", "type": "array", "items": ["devices[].tuya_device_id", "devices[].display_name", "devices[].display_type", "devices[].temperature_unit", "devices[].expose_dry_mode_switch", "devices[].expose_fan_only_mode_switch", "devices[].expose_swing_control", "devices[].expose_sleep_mode_switch", "devices[].polling_interval_seconds", "devices[].unresponsive_after_failures"] }] },
    { "type": "section", "title": "Advanced", "expandable": true, "expanded": false, "items": ["advanced_settings.request_timeout_ms", "advanced_settings.max_command_retries", "advanced_settings.command_verify_interval_ms", "advanced_settings.debug_logging"] }
  ]
}
